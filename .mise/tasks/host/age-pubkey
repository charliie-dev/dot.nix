#!/usr/bin/env bash
#MISE description="Get or generate age public key from remote host"
#USAGE arg "<hostname>" help="Remote hostname (SSH reachable)"
# shellcheck disable=SC2154 # usage_hostname is set by mise USAGE
# shellcheck disable=SC2029 # intentional client-side expansion of $KEY_FILE/$KEY_DIR
set -euo pipefail

HOST="${usage_hostname?}"
KEY_DIR=".config/age"
KEY_FILE="$KEY_DIR/keys.txt"

echo "[INFO] Checking age key on ${HOST}..."

# Check if age CLI is installed on remote
ssh "$HOST" "command -v age-keygen >/dev/null 2>&1" || {
  echo "[ERROR] age is not installed on ${HOST}. Install it first:"
  echo "  ssh ${HOST} 'sudo apt install -y age'  # or: nix profile install nixpkgs#age"
  exit 1
}

# Get or generate age key on remote
PUBKEY=$(ssh "$HOST" "
  if [ ! -f ~/$KEY_FILE ]; then
    echo '[INFO] No age key found, generating...' >&2
    mkdir -p ~/$KEY_DIR
    age-keygen -o ~/$KEY_FILE 2>&1 | grep 'public key:' | awk '{print \$NF}'
  else
    echo '[INFO] Age key already exists.' >&2
    age-keygen -y ~/$KEY_FILE
  fi
")

echo "[OK] Remote age public key for ${HOST}:"
echo "$PUBKEY"

# vim: ft=sh
