#!/usr/bin/env bash
set -e

FORCE=0
DRY_RUN=0
ASSUME_YES=0
PROTECTED='^(main|master|develop|dev)$'

for arg in "$@"; do
    case "$arg" in
        -f|--force)   FORCE=1 ;;
        -n|--dry-run) DRY_RUN=1 ;;
        -y|--yes)     ASSUME_YES=1 ;;
        -h|--help)
            cat <<EOF
Usage: git sweep [-f|--force] [-n|--dry-run] [-y|--yes]

Delete stale local branches.

On GitHub repos (origin on github.com, gh installed & authenticated) this
delegates to 'gh poi', which decides by PR state — so it also catches
squash/rebase merges and cleans up associated worktrees. On any other forge
(or when gh is unavailable) it falls back to the git-native mechanism:
branches whose upstream is gone.

Options:
  -f, --force     Force delete (git branch -D). Fallback path only; ignored
                  on the gh poi path, which never force-deletes.
  -n, --dry-run   Show what would be deleted without deleting
  -y, --yes       Skip confirmation (for non-interactive use, e.g. mise tasks)
  -h, --help      Show this help
EOF
            exit 0
            ;;
    esac
done

# On GitHub, delegate to gh poi: it judges by PR state (squash/rebase aware)
# and handles associated worktrees itself, which the git-native [gone] sweep
# below cannot. Only github.com; anything else (GHE, GitLab, offline, or gh
# not logged in) falls through to the fallback so the command always works.
origin_url=$(git remote get-url origin 2>/dev/null || true)
if [[ "$origin_url" == *github.com* ]] \
    && command -v gh >/dev/null 2>&1 \
    && gh auth status >/dev/null 2>&1; then
    # Mirror the fallback's protected set regardless of the repo's lock state.
    # Idempotent; ignore branches that don't exist locally.
    gh poi lock main master develop dev >/dev/null 2>&1 || true

    if [ "$DRY_RUN" -eq 1 ]; then
        exec gh poi --scan deep --dry-run
    fi
    if [ "$ASSUME_YES" -eq 1 ]; then
        exec gh poi --scan deep
    fi
    # Preview then confirm, matching the fallback UX.
    gh poi --scan deep --dry-run
    printf "Proceed with deletion via gh poi? [y/N] "
    read -r ans || ans=""
    if [ "$ans" != "y" ] && [ "$ans" != "Y" ]; then
        echo "Aborted."
        exit 0
    fi
    exec gh poi --scan deep
fi

git fetch -p

# Drop metadata for worktrees whose directory was removed by hand. Such a
# stale entry would otherwise keep a branch "checked out" and block its
# deletion below (see gh-poi #180/#181).
git worktree prune

branches=$(git branch -vv | awk '/: gone]/ { if ($1 == "*" || $1 == "+") print $2; else print $1 }' | grep -vE "$PROTECTED" || true)

if [ "$branches" = "" ]; then
    echo "✓ No stale branches to clean."
    exit 0
fi

echo "Stale branches (upstream gone):"
echo "  - ${branches//$'\n'/$'\n'  - }"

if [ "$DRY_RUN" -eq 1 ]; then
    echo "(dry-run, nothing deleted)"
    exit 0
fi

if [ "$ASSUME_YES" -eq 1 ]; then
    ans=y
else
    if [ "$FORCE" -eq 1 ]; then
        printf "Proceed with FORCE delete? [y/N] "
    else
        printf "Proceed? [y/N] "
    fi
    # `read` returns non-zero on EOF (non-interactive stdin); guard so `set -e`
    # doesn't abort the whole script and treat a plain no-op as a failure.
    read -r ans || ans=""
fi
if [ "$ans" != "y" ] && [ "$ans" != "Y" ]; then
    echo "Aborted."
    exit 0
fi

flag="-d"
[ "$FORCE" -eq 1 ] && flag="-D"

# Free the worktree (if any) holding a stale branch so it can be deleted.
# Args: branch path is-main is-locked is-prunable. Returns non-zero when the
# worktree can't be released safely, so the caller skips that branch.
release_worktree() {
    local br="$1" wt="$2" is_main="$3" is_locked="$4" is_prunable="$5"

    if [ "$is_main" = "1" ]; then
        echo "  '$br' is checked out in the main worktree; switch away to delete it"
        return 1
    fi
    if [ "$is_locked" = "1" ]; then
        echo "  '$br' is in a locked worktree ($wt); unlock it then re-run"
        return 1
    fi

    echo "  '$br' is checked out in worktree: $wt"
    if [ "$is_prunable" = "1" ]; then
        git worktree prune
        echo "    pruned stale worktree"
        return 0
    fi
    # No --force: git refuses to remove a dirty worktree, which is exactly the
    # safe behaviour we want (never discard uncommitted work).
    if git worktree remove "$wt" 2>/dev/null; then
        echo "    removed worktree"
        return 0
    fi
    echo "    ! worktree is dirty; skipping '$br'"
    echo "      resolve it then re-run, or: git worktree remove --force '$wt'"
    return 1
}

skipped=""
while IFS= read -r br; do
    [ -z "$br" ] && continue

    # Look up the worktree (if any) holding this branch and its porcelain
    # flags, tab-separated: path, is-main, is-locked, is-prunable. Paragraph
    # mode ($1 record = the main worktree) keeps the path intact even with
    # spaces.
    info=$(git worktree list --porcelain | awk -v b="branch refs/heads/$br" '
        BEGIN { RS = ""; FS = "\n" }
        {
            path = ""; ismain = (NR == 1) ? 1 : 0; locked = 0; prunable = 0; hit = 0
            for (i = 1; i <= NF; i++) {
                if ($i ~ /^worktree /)     path = substr($i, 10)
                else if ($i ~ /^locked/)   locked = 1
                else if ($i ~ /^prunable/) prunable = 1
                else if ($i == b)          hit = 1
            }
            if (hit) { printf "%s\t%d\t%d\t%d\n", path, ismain, locked, prunable; exit }
        }')

    if [ -n "$info" ]; then
        IFS=$'\t' read -r wt is_main is_locked is_prunable <<<"$info"
        if ! release_worktree "$br" "$wt" "$is_main" "$is_locked" "$is_prunable"; then
            skipped="$skipped $br"
            continue
        fi
    fi

    if ! git branch "$flag" "$br"; then
        skipped="$skipped $br"
    fi
done <<EOF
$branches
EOF

if [ -n "$skipped" ]; then
    echo "Skipped (needs manual attention):$skipped"
    exit 1
fi
