#!/usr/bin/env bash
set -e

FORCE=0
DRY_RUN=0
ASSUME_YES=0
PROTECTED='^(main|master|develop|dev)$'

for arg in "$@"; do
    case "$arg" in
        -f|--force)   FORCE=1 ;;
        -n|--dry-run) DRY_RUN=1 ;;
        -y|--yes)     ASSUME_YES=1 ;;
        -h|--help)
            cat <<EOF
Usage: git sweep [-f|--force] [-n|--dry-run] [-y|--yes]

Delete stale local branches.

On GitHub repos (origin on github.com, gh installed & authenticated) this
delegates to 'gh poi', which decides by PR state — so it also catches
squash/rebase merges and cleans up associated worktrees. On any other forge
(or when gh is unavailable) it falls back to the git-native mechanism:
branches whose upstream is gone.

Options:
  -f, --force     Force delete (git branch -D). Fallback path only; ignored
                  on the gh poi path, which never force-deletes.
  -n, --dry-run   Show what would be deleted without deleting
  -y, --yes       Skip confirmation (for non-interactive use, e.g. mise tasks)
  -h, --help      Show this help
EOF
            exit 0
            ;;
    esac
done

# On GitHub, delegate to gh poi: it judges by PR state (squash/rebase aware)
# and handles associated worktrees itself, which the git-native [gone] sweep
# below cannot. Only github.com; anything else (GHE, GitLab, offline, or gh
# not logged in) falls through to the fallback so the command always works.
origin_url=$(git remote get-url origin 2>/dev/null || true)
if [[ "$origin_url" == *github.com* ]] \
    && command -v gh >/dev/null 2>&1 \
    && gh auth status >/dev/null 2>&1; then
    # Mirror the fallback's protected set regardless of the repo's lock state.
    # Idempotent; ignore branches that don't exist locally.
    gh poi lock main master develop dev >/dev/null 2>&1 || true

    if [ "$DRY_RUN" -eq 1 ]; then
        exec gh poi --scan deep --dry-run
    fi
    if [ "$ASSUME_YES" -eq 1 ]; then
        exec gh poi --scan deep
    fi
    # Preview then confirm, matching the fallback UX.
    gh poi --scan deep --dry-run
    printf "Proceed with deletion via gh poi? [y/N] "
    read -r ans || ans=""
    if [ "$ans" != "y" ] && [ "$ans" != "Y" ]; then
        echo "Aborted."
        exit 0
    fi
    exec gh poi --scan deep
fi

git fetch -p

branches=$(git branch -vv | awk '/: gone]/ { if ($1 == "*" || $1 == "+") print $2; else print $1 }' | grep -vE "$PROTECTED" || true)

if [ "$branches" = "" ]; then
    echo "✓ No stale branches to clean."
    exit 0
fi

echo "Stale branches (upstream gone):"
echo "  - ${branches//$'\n'/$'\n'  - }"

if [ "$DRY_RUN" -eq 1 ]; then
    echo "(dry-run, nothing deleted)"
    exit 0
fi

if [ "$ASSUME_YES" -eq 1 ]; then
    ans=y
else
    if [ "$FORCE" -eq 1 ]; then
        printf "Proceed with FORCE delete? [y/N] "
    else
        printf "Proceed? [y/N] "
    fi
    # `read` returns non-zero on EOF (non-interactive stdin); guard so `set -e`
    # doesn't abort the whole script and treat a plain no-op as a failure.
    read -r ans || ans=""
fi
if [ "$ans" != "y" ] && [ "$ans" != "Y" ]; then
    echo "Aborted."
    exit 0
fi

flag="-d"
[ "$FORCE" -eq 1 ] && flag="-D"

skipped=""
while IFS= read -r br; do
    [ -z "$br" ] && continue

    # A branch checked out in a linked worktree can't be deleted until the
    # worktree is gone. Look it up in the porcelain listing (path may contain
    # spaces, so slice after the "worktree " prefix rather than field-split).
    wt=$(git worktree list --porcelain | awk -v b="refs/heads/$br" '
        /^worktree / { p = substr($0, 10) }
        $0 == "branch " b { print p; exit }')

    if [ -n "$wt" ]; then
        echo "  '$br' is checked out in worktree: $wt"
        # No --force: git refuses to remove a dirty/locked worktree, which is
        # exactly the safe behaviour we want (never discard uncommitted work).
        if git worktree remove "$wt" 2>/dev/null; then
            echo "    removed worktree"
        else
            echo "    ! worktree is dirty or locked; skipping '$br'"
            echo "      resolve it then re-run, or: git worktree remove --force '$wt'"
            skipped="$skipped $br"
            continue
        fi
    fi

    if ! git branch "$flag" "$br"; then
        skipped="$skipped $br"
    fi
done <<EOF
$branches
EOF

if [ -n "$skipped" ]; then
    echo "Skipped (needs manual attention):$skipped"
    exit 1
fi
